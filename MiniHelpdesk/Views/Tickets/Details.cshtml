@model MiniHelpdesk.ViewModels.TicketDetailsViewModel

@{
    ViewData["Title"] = "Ticket details";
}

<h1>Ticket details</h1>

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h4">@Model.Ticket.Title</h2>

        <dl class="row">
            <dt class="col-sm-3">Id</dt>
            <dd class="col-sm-9">@Model.Ticket.Id</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Ticket.Status</dd>

            <dt class="col-sm-3">Created at</dt>
            <dd class="col-sm-9">@Model.Ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">
                @if (string.IsNullOrWhiteSpace(Model.Ticket.Description))
                {
                    <span class="text-muted">No description</span>
                }
                else
                {
                    @Model.Ticket.Description
                }
            </dd>
        </dl>

        @if (Model.Ticket.Status != MiniHelpdesk.Models.TicketStatus.Closed)
        {
            <form asp-action="Close" asp-route-id="@Model.Ticket.Id" method="post">
                <button type="submit" class="btn btn-warning">Close ticket</button>
            </form>
        }
    </div>
</div>

<h2 class="h4">Comments</h2>

@if (!Model.Comments.Any())
{
    <div class="alert alert-info">
        There are no comments for this ticket.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Author</th>
            <th>Content</th>
            <th>Created at</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var comment in Model.Comments)
        {
            <tr>
                <td>@comment.Author</td>
                <td>@comment.Content</td>
                <td>@comment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        }
        </tbody>
    </table>
}

<p>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</p>